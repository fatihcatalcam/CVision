# CVision Production Environment Variables (Windows VPS)
# Copy this file to .env and fill in the values

# Database Connection (PostgreSQL Windows Native)
# Format: postgresql://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql://postgres:your_strong_password@localhost:5432/cvision_db

# Security
# Generate a random secret key using: openssl rand -hex 32
SECRET_KEY=your_very_secret_random_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Application
APP_NAME=CVision
DEBUG=False
CORS_ORIGINS=["http://localhost", "http://<YOUR_VPS_IP>"]

# Paths
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
